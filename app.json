{
  "expo": {
    "name": "NexoApp",
    "slug": "NexoApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
      ],
      "package": "com.stito.NexoApp"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "react-native-wifi-reborn"
    ],
    "extra": {
      "eas": {
        "projectId": "5d3e920f-be07-4bf2-914e-d0baab55b0e5"
      }
    }
  }
}
